/* =============================================================
   G Folio — Admin Stylesheet
   Scoped to G Folio admin pages only via PHP enqueue hook
   ============================================================= */

/* ---- Custom Properties ---- */
:root {
  --gf-primary:       #7c3aed;
  --gf-primary-light: #a78bfa;
  --gf-primary-dark:  #5b21b6;
  --gf-surface:       #ffffff;
  --gf-surface-alt:   #f8f7fc;
  --gf-border:        #e2e0f0;
  --gf-text:          #1e1b3a;
  --gf-text-muted:    #6b6987;
  --gf-success:       #059669;
  --gf-danger:        #dc2626;
  --gf-radius:        10px;
  --gf-shadow:        0 2px 12px rgba(124, 58, 237, 0.08);
  --gf-shadow-md:     0 4px 20px rgba(124, 58, 237, 0.14);
  --gf-transition:    0.2s ease;
}

/* ============================================================
   SETTINGS PAGE
   ============================================================ */

.gfolio-settings-wrap {
  max-width: 960px;
  margin: 24px 20px 0 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

/* ---- Header ---- */
.gfolio-settings-header {
  background: linear-gradient(135deg, #1e1b3a 0%, #3b1fa3 100%);
  border-radius: var(--gf-radius);
  padding: 28px 32px;
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gfolio-settings-brand {
  display: flex;
  align-items: center;
  gap: 16px;
}

.gfolio-brand-icon {
  font-size: 40px !important;
  width: 40px !important;
  height: 40px !important;
  color: var(--gf-primary-light);
}

.gfolio-settings-title {
  color: #ffffff !important;
  font-size: 24px !important;
  margin: 0 0 4px !important;
  padding: 0 !important;
  font-weight: 700;
  letter-spacing: -0.3px;
}

.gfolio-settings-subtitle {
  color: rgba(255, 255, 255, 0.65);
  margin: 0;
  font-size: 14px;
}

/* ---- Notice ---- */
.gfolio-notice {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 20px;
  border-radius: var(--gf-radius);
  margin-bottom: 20px;
  font-size: 14px;
  font-weight: 500;
}

.gfolio-notice-success {
  background: #ecfdf5;
  border: 1px solid #6ee7b7;
  color: var(--gf-success);
}

.gfolio-notice .dashicons {
  font-size: 20px;
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

/* ---- Shortcode Bar ---- */
.gfolio-shortcode-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--gf-surface-alt);
  border: 1px solid var(--gf-border);
  border-radius: var(--gf-radius);
  padding: 12px 20px;
  margin-bottom: 24px;
}

.gfolio-shortcode-label {
  font-weight: 600;
  font-size: 13px;
  color: var(--gf-text-muted);
  white-space: nowrap;
}

.gfolio-shortcode-code {
  background: #1e1b3a;
  color: var(--gf-primary-light);
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 13px;
  font-family: "SF Mono", "Fira Code", monospace;
  white-space: nowrap;
}

.gfolio-shortcode-hint {
  font-size: 13px;
  color: var(--gf-text-muted);
}

/* ---- Tabs Navigation ---- */
.gfolio-tabs-nav {
  display: flex;
  gap: 4px;
  background: var(--gf-surface-alt);
  border: 1px solid var(--gf-border);
  border-radius: var(--gf-radius) var(--gf-radius) 0 0;
  padding: 8px 8px 0;
  overflow-x: auto;
}

.gfolio-tab-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 18px;
  border: none;
  background: transparent;
  border-radius: 8px 8px 0 0;
  color: var(--gf-text-muted);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  transition: background var(--gf-transition), color var(--gf-transition);
  position: relative;
  bottom: -1px;
}

.gfolio-tab-btn:hover {
  background: rgba(124, 58, 237, 0.08);
  color: var(--gf-primary);
}

.gfolio-tab-btn.is-active {
  background: var(--gf-surface);
  color: var(--gf-primary);
  border: 1px solid var(--gf-border);
  border-bottom-color: var(--gf-surface);
  font-weight: 600;
}

.gfolio-tab-btn .dashicons {
  font-size: 16px;
  width: 16px;
  height: 16px;
}

/* ---- Tab Panels ---- */
.gfolio-tabs-content {
  background: var(--gf-surface);
  border: 1px solid var(--gf-border);
  border-top: none;
  border-radius: 0 0 var(--gf-radius) var(--gf-radius);
  padding: 28px;
}

.gfolio-tab-panel {
  display: none;
}

.gfolio-tab-panel.is-active {
  display: block;
  animation: gfolio-fade-in 0.2s ease;
}

@keyframes gfolio-fade-in {
  from { opacity: 0; transform: translateY(4px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ---- Settings Card ---- */
.gfolio-settings-card {
  background: var(--gf-surface);
  border: 1px solid var(--gf-border);
  border-radius: var(--gf-radius);
  padding: 24px;
  box-shadow: var(--gf-shadow);
}

.gfolio-card-title {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 16px !important;
  font-weight: 700;
  color: var(--gf-text);
  margin: 0 0 20px !important;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--gf-border);
}

.gfolio-card-title .dashicons {
  color: var(--gf-primary);
  font-size: 20px;
  width: 20px;
  height: 20px;
}

.gfolio-card-desc {
  color: var(--gf-text-muted);
  font-size: 13px;
  margin: -10px 0 20px;
}

.gfolio-subsection-title {
  font-size: 14px !important;
  font-weight: 600;
  color: var(--gf-text);
  margin: 20px 0 16px !important;
}

/* ---- Setting Row ---- */
.gfolio-setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 16px 0;
  border-bottom: 1px solid var(--gf-border);
}

.gfolio-setting-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.gfolio-setting-row:first-child {
  padding-top: 0;
}

.gfolio-setting-label {
  flex: 1;
  min-width: 0;
}

.gfolio-setting-label label {
  display: block;
  font-weight: 600;
  font-size: 13px;
  color: var(--gf-text);
  margin-bottom: 4px;
}

.gfolio-setting-desc {
  display: block;
  font-size: 12px;
  color: var(--gf-text-muted);
  line-height: 1.4;
}

.gfolio-setting-control {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}

.gfolio-setting-control.gfolio-full-width {
  width: 100%;
  flex-shrink: 1;
}

.gfolio-toggle-with-sub {
  flex-direction: column;
  align-items: flex-start;
}

.gfolio-settings-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 32px;
}

/* ---- Toggle Switches ---- */
.gfolio-toggle-switch {
  position: relative;
  display: inline-flex;
  align-items: center;
  cursor: pointer;
  flex-shrink: 0;
}

.gfolio-toggle-switch input[type="checkbox"] {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
  margin: 0;
}

.gfolio-toggle-slider {
  position: relative;
  display: inline-block;
  width: 44px;
  height: 24px;
  background: #d1d5db;
  border-radius: 100px;
  transition: background var(--gf-transition);
  flex-shrink: 0;
}

.gfolio-toggle-slider::after {
  content: "";
  position: absolute;
  top: 3px;
  left: 3px;
  width: 18px;
  height: 18px;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  transition: transform var(--gf-transition);
}

.gfolio-toggle-switch input:checked + .gfolio-toggle-slider {
  background: var(--gf-primary);
}

.gfolio-toggle-switch input:checked + .gfolio-toggle-slider::after {
  transform: translateX(20px);
}

.gfolio-toggle-switch input:focus-visible + .gfolio-toggle-slider {
  outline: 2px solid var(--gf-primary);
  outline-offset: 2px;
}

/* ---- Segmented Control ---- */
.gfolio-segmented-control {
  display: inline-flex;
  background: var(--gf-surface-alt);
  border: 1px solid var(--gf-border);
  border-radius: 8px;
  padding: 3px;
  gap: 2px;
}

.gfolio-segment {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  color: var(--gf-text-muted);
  cursor: pointer;
  transition: background var(--gf-transition), color var(--gf-transition);
}

.gfolio-segment input[type="radio"] {
  display: none;
}

.gfolio-segment.is-active,
.gfolio-segment:has(input:checked) {
  background: var(--gf-surface);
  color: var(--gf-primary);
  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
}

.gfolio-segment .dashicons {
  font-size: 15px;
  width: 15px;
  height: 15px;
}

/* ---- Slider ---- */
.gfolio-slider-wrap {
  display: flex;
  align-items: center;
  gap: 14px;
  min-width: 200px;
}

.gfolio-slider {
  -webkit-appearance: none;
  appearance: none;
  width: 160px;
  height: 6px;
  background: var(--gf-border);
  border-radius: 100px;
  outline: none;
  cursor: pointer;
}

.gfolio-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--gf-primary);
  box-shadow: 0 1px 4px rgba(124, 58, 237, 0.4);
  cursor: pointer;
  transition: transform 0.1s;
}

.gfolio-slider::-webkit-slider-thumb:hover {
  transform: scale(1.15);
}

.gfolio-slider::-moz-range-thumb {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: none;
  background: var(--gf-primary);
  cursor: pointer;
}

.gfolio-slider-value {
  font-size: 14px;
  font-weight: 700;
  color: var(--gf-primary);
  min-width: 24px;
  text-align: center;
}

/* ---- Selects ---- */
.gfolio-select {
  height: 38px;
  padding: 0 32px 0 12px;
  border: 1px solid var(--gf-border);
  border-radius: 8px;
  font-size: 13px;
  color: var(--gf-text);
  background: var(--gf-surface);
  cursor: pointer;
  min-width: 180px;
  appearance: auto;
}

.gfolio-select:focus {
  outline: none;
  border-color: var(--gf-primary);
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.12);
}

/* ---- Number input ---- */
.gfolio-number-input {
  width: 70px;
  height: 38px;
  padding: 0 10px;
  border: 1px solid var(--gf-border);
  border-radius: 8px;
  font-size: 13px;
  text-align: center;
}

.gfolio-unit {
  font-size: 13px;
  color: var(--gf-text-muted);
}

/* ---- Color Row ---- */
.gfolio-color-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* Override WP color picker wrapper */
.gfolio-settings-wrap .wp-picker-container {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.gfolio-settings-wrap .wp-color-result.button {
  border-radius: 8px !important;
  border: 1px solid var(--gf-border) !important;
  height: 36px;
}

/* ---- Radio Options (Settings) ---- */
.gfolio-radio-settings {
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12px;
  width: 100%;
}

.gfolio-radio-settings .gfolio-radio-option {
  flex: 1;
  min-width: 160px;
}

/* ---- Button Style Picker (Settings) ---- */
.gfolio-btn-style-picker {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.gfolio-style-option {
  cursor: pointer;
}

.gfolio-style-option input[type="radio"] {
  display: none;
}

.gfolio-style-preview {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 100px;
  padding: 8px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  border: 2px solid transparent;
  transition: border-color var(--gf-transition), transform 0.1s;
}

.gfolio-style-filled {
  background: #1e1b3a;
  color: #ffffff;
}

.gfolio-style-outlined {
  background: transparent;
  color: #1e1b3a;
  border: 2px solid #1e1b3a;
}

.gfolio-style-ghost {
  background: transparent;
  color: #1e1b3a;
  text-decoration: underline;
}

.gfolio-style-option.is-active .gfolio-style-preview,
.gfolio-style-option:has(input:checked) .gfolio-style-preview {
  border-color: var(--gf-primary);
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.12);
  transform: scale(1.02);
}

/* ---- Divider ---- */
.gfolio-divider {
  border: none;
  border-top: 1px solid var(--gf-border);
  margin: 24px 0;
}

/* ---- Save Button ---- */
.gfolio-settings-footer {
  padding: 24px 0 0;
  border-top: 1px solid var(--gf-border);
  margin-top: 24px;
}

.gfolio-save-btn.button-primary {
  background: var(--gf-primary) !important;
  border-color: var(--gf-primary-dark) !important;
  color: #ffffff !important;
  padding: 10px 28px !important;
  height: auto !important;
  font-size: 14px !important;
  font-weight: 600 !important;
  border-radius: 8px !important;
  box-shadow: 0 2px 8px rgba(124, 58, 237, 0.35) !important;
  transition: transform 0.1s, box-shadow 0.1s !important;
}

.gfolio-save-btn.button-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 14px rgba(124, 58, 237, 0.4) !important;
}

/* =============================================================
   META BOX STYLES (Portfolio Item Edit Screen)
   ============================================================= */

/* ---- Media Box ---- */
.gfolio-media-box {
  padding: 4px 0;
}

.gfolio-thumb-preview {
  width: 100%;
  aspect-ratio: 16/10;
  background: var(--gf-surface-alt);
  border: 2px dashed var(--gf-border);
  border-radius: var(--gf-radius);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.gfolio-thumb-preview img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.gfolio-thumb-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: var(--gf-text-muted);
  padding: 20px;
  text-align: center;
}

.gfolio-thumb-placeholder .dashicons {
  font-size: 40px;
  width: 40px;
  height: 40px;
  color: var(--gf-border);
}

.gfolio-thumb-placeholder p {
  margin: 0;
  font-size: 12px;
}

.gfolio-media-buttons {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
}

.gfolio-upload-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  background: var(--gf-primary) !important;
  border-color: var(--gf-primary-dark) !important;
  color: #fff !important;
  border-radius: 6px !important;
}

.gfolio-remove-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  color: var(--gf-danger) !important;
  border-color: #fca5a5 !important;
  border-radius: 6px !important;
}

/* ---- Meta Sections ---- */
.gfolio-meta-section {
  padding: 4px 0 8px;
}

.gfolio-section-desc {
  color: var(--gf-text-muted);
  font-size: 12px;
  margin: 0 0 16px;
}

/* ---- Field Rows ---- */
.gfolio-field-row {
  margin-bottom: 20px;
}

.gfolio-field-row:last-child {
  margin-bottom: 0;
}

.gfolio-field-label {
  display: block;
  font-weight: 600;
  font-size: 12px;
  color: var(--gf-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.6px;
  margin-bottom: 8px !important;
}

.gfolio-label-large {
  font-size: 13px !important;
  text-transform: none;
  letter-spacing: 0;
  color: var(--gf-text) !important;
  font-weight: 600 !important;
}

.gfolio-field-hint {
  display: block;
  font-size: 11px;
  color: var(--gf-text-muted);
  margin-top: 5px;
  line-height: 1.4;
}

/* ---- Text Inputs ---- */
.gfolio-text-input {
  width: 100%;
  height: 38px;
  padding: 0 12px;
  border: 1px solid var(--gf-border);
  border-radius: 8px;
  font-size: 13px;
  color: var(--gf-text);
  box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  transition: border-color var(--gf-transition), box-shadow var(--gf-transition);
  box-sizing: border-box;
}

.gfolio-text-input:focus {
  outline: none;
  border-color: var(--gf-primary);
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.12);
}

/* ---- Textarea ---- */
.gfolio-textarea {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid var(--gf-border);
  border-radius: 8px;
  font-size: 13px;
  color: var(--gf-text);
  resize: vertical;
  transition: border-color var(--gf-transition), box-shadow var(--gf-transition);
  box-sizing: border-box;
  line-height: 1.5;
}

.gfolio-textarea:focus {
  outline: none;
  border-color: var(--gf-primary);
  box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.12);
}

/* ---- Radio Options (Meta Box) ---- */
.gfolio-radio-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}

.gfolio-radio-option {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border: 2px solid var(--gf-border);
  border-radius: 10px;
  cursor: pointer;
  transition: border-color var(--gf-transition), background var(--gf-transition);
}

.gfolio-radio-option:hover {
  background: var(--gf-surface-alt);
  border-color: var(--gf-primary-light);
}

.gfolio-radio-option.is-active,
.gfolio-radio-option:has(input:checked) {
  border-color: var(--gf-primary);
  background: rgba(124, 58, 237, 0.04);
}

.gfolio-radio-option input[type="radio"] {
  display: none;
}

.gfolio-radio-icon {
  width: 36px;
  height: 36px;
  background: var(--gf-surface-alt);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--gf-primary);
}

.gfolio-radio-option.is-active .gfolio-radio-icon {
  background: rgba(124, 58, 237, 0.12);
}

.gfolio-radio-label {
  font-weight: 600;
  font-size: 13px;
  color: var(--gf-text);
}

.gfolio-radio-desc {
  font-size: 11px;
  color: var(--gf-text-muted);
  margin-left: auto;
}

/* ---- Info Box ---- */
.gfolio-info-box {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  background: #eef2ff;
  border: 1px solid #c7d2fe;
  border-radius: 8px;
  padding: 10px 14px;
  margin-bottom: 16px;
  font-size: 12px;
  color: #3730a3;
  line-height: 1.5;
}

.gfolio-info-box .dashicons {
  font-size: 16px;
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  margin-top: 1px;
}

/* ---- Click Sub-Fields ---- */
.gfolio-click-sub-field {
  background: var(--gf-surface-alt);
  border: 1px solid var(--gf-border);
  border-radius: 8px;
  padding: 14px;
  margin-bottom: 12px;
}

/* ---- Toggle Row (inline) ---- */
.gfolio-toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  cursor: pointer;
}

.gfolio-toggle-master {
  padding-bottom: 8px;
}

/* ---- Checkbox Group ---- */
.gfolio-checkbox-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.gfolio-checkbox-row {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  font-size: 13px;
  color: var(--gf-text);
}

/* ---- Plain Checkbox (replaces toggle switch) ---- */
.gfolio-checkbox-plain {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 13px;
  font-weight: 500;
  color: var(--gf-text);
  cursor: pointer;
}

.gfolio-checkbox-plain input[type="checkbox"] {
  width: 16px;
  height: 16px;
  margin: 0;
  cursor: pointer;
  accent-color: var(--gf-primary);
  flex-shrink: 0;
}

/* ---- Expand/Button Fields (hidden until enabled) ---- */
.gfolio-btn-fields,
.gfolio-expand-fields,
.gfolio-padding-size-wrap {
  padding-top: 16px;
  margin-top: 8px;
  border-top: 1px solid var(--gf-border);
}

/* ---- Utility ---- */
.hidden {
  display: none !important;
}

/* Override WP metabox heading */
#gfolio_media_box h2.hndle,
#gfolio_assign_portfolio_box h2.hndle,
#gfolio_details_box h2.hndle,
#gfolio_click_behavior_box h2.hndle,
#gfolio_project_button_box h2.hndle,
#gfolio_expand_panel_box h2.hndle,
#gfolio_shortcode_box h2.hndle,
#gfolio_portfolio_settings_box h2.hndle {
  font-size: 13px;
  font-weight: 700;
  color: var(--gf-text);
  padding: 8px 12px;
}

/* ---- Portfolio shortcode display (meta box) ---- */
.gfolio-shortcode-display {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #1e1b3a;
  border-radius: 8px;
  padding: 10px 14px;
  margin-top: 8px;
}

.gfolio-shortcode-display code {
  color: var(--gf-primary-light);
  font-family: "SF Mono", "Fira Code", monospace;
  font-size: 13px;
  background: transparent;
  padding: 0;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.gfolio-copy-shortcode-btn {
  flex-shrink: 0;
  display: flex !important;
  align-items: center;
  gap: 4px;
  background: var(--gf-primary) !important;
  color: #fff !important;
  border-color: var(--gf-primary-dark) !important;
  border-radius: 6px !important;
  font-size: 12px !important;
}

.gfolio-copy-shortcode-btn:hover {
  background: var(--gf-primary-dark) !important;
}

.gfolio-copy-shortcode-btn .dashicons {
  font-size: 14px !important;
  width: 14px !important;
  height: 14px !important;
}

/* ---- Portfolio settings box sub-headings ---- */
.gfolio-box-subheading {
  font-size: 12px !important;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.7px;
  color: var(--gf-text-muted);
  margin: 20px 0 10px !important;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--gf-border);
}

.gfolio-box-subheading:first-child {
  margin-top: 0 !important;
}

/* ---- Category group labels (when item is in multiple portfolios) ---- */
.gfolio-cat-group-label {
  font-size: 11px !important;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--gf-text-muted);
  margin: 12px 0 6px !important;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--gf-border);
}

.gfolio-cat-group-label:first-child {
  margin-top: 0 !important;
}

/* ---- Combined portfolio + inline categories ---- */
.gfolio-portfolio-cat-list {
  padding: 0;
}

.gfolio-portfolio-row {
  border-bottom: 1px solid var(--gf-border);
  padding: 8px 0;
}

.gfolio-portfolio-row:last-of-type {
  border-bottom: none;
}

/* Portfolio row header: checkbox+name on left, toggle arrow on right */
.gfolio-portfolio-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.gfolio-portfolio-label {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  font-weight: 600;
  font-size: 13px;
  color: var(--gf-text);
  user-select: none;
  flex: 1;
  min-width: 0;
}

.gfolio-portfolio-label input[type="checkbox"] {
  width: 16px;
  height: 16px;
  margin: 0;
  accent-color: var(--gf-primary);
  flex-shrink: 0;
  cursor: pointer;
}

.gfolio-portfolio-name {
  line-height: 1.3;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Accordion toggle arrow button */
.gfolio-accordion-toggle {
  flex-shrink: 0;
  background: none;
  border: none;
  padding: 2px;
  cursor: pointer;
  color: var(--gf-text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  transition: color var(--gf-transition), background var(--gf-transition);
}

.gfolio-accordion-toggle:hover {
  color: var(--gf-primary);
  background: rgba(124, 58, 237, 0.08);
}

.gfolio-accordion-toggle .dashicons {
  font-size: 16px;
  width: 16px;
  height: 16px;
  transition: transform 0.2s ease;
  transform: rotate(-90deg); /* points right when closed */
}

.gfolio-accordion-toggle.is-open .dashicons {
  transform: rotate(0deg); /* points down when open */
}

/* Indented category list that slides in below each portfolio */
.gfolio-inline-cats {
  padding: 8px 0 4px 24px;
}

.gfolio-checkbox-group--indent {
  gap: 6px;
}

.gfolio-field-hint--indent {
  padding-left: 0;
  margin: 4px 0 0;
  font-size: 11px;
}

/* Make the post editor two-column feel */
#poststuff #post-body.columns-2 #postbox-container-2 {
  margin-right: 0;
}
